<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================
         HOME PAGE
         ============================================================ -->
    <template id="homepage" name="Bhuarjan – Home">
        <t t-call="website.layout">
            <t t-set="no_header" t-value="1"/>
            <t t-set="no_footer" t-value="1"/>
            <t t-set="head">
                <link rel="stylesheet" type="text/css"
                      t-att-href="'/bhuarjan_web/static/src/css/bhuarjan_website.css'"/>
                <link rel="stylesheet"
                      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"/>
                <link rel="preconnect" href="https://fonts.googleapis.com"/>
                <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous"/>
                <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&amp;display=swap"
                      rel="stylesheet"/>
                <script type="text/javascript" src="/bhuarjan_web/static/src/js/bhuarjan_website.js"/>
            </t>

            <!-- ── NAVBAR ── -->
            <t t-call="bhuarjan_web.navbar"/>

            <!-- ============================================================
                 HERO
                 ============================================================ -->
            <section class="bhu-hero">
                <div class="bhu-hero-inner">
                    <div class="bhu-hero-left">
                        <span class="bhu-hero-pill">
                            <span class="dot"/> District Administration Raigarh
                        </span>
                        <h1>The future of <span class="accent">Land Acquisition</span> Management</h1>
                        <p class="bhu-hero-system">Bhuarjan LAMS — A Government of Chhattisgarh Initiative</p>
                        <p class="bhu-hero-desc">
                            A unified digital platform streamlining every stage of the land
                            acquisition process — from initial survey to final compensation —
                            ensuring real‑time monitoring, full transparency, and complete
                            accountability across all administrative levels.
                        </p>
                        <div class="bhu-hero-actions">
                            <a href="/odoo" class="bhu-btn primary">
                                Get Started <i class="fa fa-arrow-right"/>
                            </a>
                            <a href="/contact" class="bhu-btn ghost">
                                <i class="fa fa-play-circle"/> Request Demo
                            </a>
                        </div>
                        <div class="bhu-hero-trust">
                            <div class="bhu-hero-trust-item">
                                <div class="num">120+</div>
                                <div class="lbl">Projects Managed</div>
                            </div>
                            <div class="bhu-hero-trust-item">
                                <div class="num">5K+</div>
                                <div class="lbl">Land Parcels</div>
                            </div>
                            <div class="bhu-hero-trust-item">
                                <div class="num">99%</div>
                                <div class="lbl">Uptime</div>
                            </div>
                        </div>
                    </div>
                    <div class="bhu-hero-visual">
                        <img class="bhu-hero-img-main"
                             src="/bhuarjan_web/static/src/img/bhuarjan_banner_2.webp"
                             alt="Bhuarjan dashboard overview"/>
                    </div>
                </div>
            </section>

            <!-- ============================================================
                 TRUSTED BAR
                 ============================================================ -->
            <section class="bhu-trusted">
                <div class="bhu-trusted-inner">
                    <span><i class="fa fa-shield-alt" style="margin-right:8px;color:#8A4531;"/> Government of Chhattisgarh</span>
                    <div class="sep"/>
                    <span><i class="fa fa-lock" style="margin-right:8px;color:#8A4531;"/> Bank-Grade Security</span>
                    <div class="sep"/>
                    <span><i class="fa fa-cloud" style="margin-right:8px;color:#8A4531;"/> Cloud Native</span>
                    <div class="sep"/>
                    <span><i class="fa fa-mobile-alt" style="margin-right:8px;color:#8A4531;"/> Mobile-First</span>
                    <div class="sep"/>
                    <span><i class="fa fa-language" style="margin-right:8px;color:#8A4531;"/> Hindi &amp; English</span>
                </div>
            </section>

            <!-- ============================================================
                 VALUE PROPS
                 ============================================================ -->
            <section class="bhu-values">
                <div class="bhu-values-inner">
                    <div class="bhu-values-img-wrap">
                        <img src="/bhuarjan_web/static/src/img/bhuarjan_image_3.webp"
                             alt="Bhuarjan platform preview"/>
                    </div>
                    <div class="bhu-values-content">
                        <span class="bhu-hero-pill" style="margin-bottom:18px;">
                            <span class="dot"/> Why Bhuarjan
                        </span>
                        <h2>Built for governance.<br/>Designed for people.</h2>
                        <p>
                            Empower every level of land administration — from Patwari to
                            Collector — with real-time data, paperless workflows, and
                            transparent processes that build community trust.
                        </p>
                        <div class="bhu-vp-grid">
                            <div class="bhu-vp-item">
                                <div class="vp-ico"><i class="fa fa-eye"/></div>
                                <div>
                                    <h4>Transparent</h4>
                                    <p>Real-time tracking of every project.</p>
                                </div>
                            </div>
                            <div class="bhu-vp-item">
                                <div class="vp-ico"><i class="fa fa-users"/></div>
                                <div>
                                    <h4>Empowering</h4>
                                    <p>Paperless coordination top-to-bottom.</p>
                                </div>
                            </div>
                            <div class="bhu-vp-item">
                                <div class="vp-ico"><i class="fa fa-map-marked-alt"/></div>
                                <div>
                                    <h4>Tech-Driven</h4>
                                    <p>GIS mapping &amp; mobile surveys.</p>
                                </div>
                            </div>
                            <div class="bhu-vp-item">
                                <div class="vp-ico"><i class="fa fa-balance-scale"/></div>
                                <div>
                                    <h4>Fair &amp; Inclusive</h4>
                                    <p>Equitable, traceable digital records.</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </section>

            <!-- ============================================================
                 KEY FEATURES (DARK)
                 ============================================================ -->
            <section class="bhu-features dark">
                <div class="bhu-features-inner">
                    <div class="bhu-sec-head">
                        <span class="tag">Platform Capabilities</span>
                        <h2>Everything you need in one platform</h2>
                        <p>From field data collection to final notification — every step is digitised, secured, and audit-ready.</p>
                    </div>
                    <div class="bhu-features-grid">
                        <div class="bhu-feature">
                            <div class="ico"><i class="fa fa-mobile-alt"/></div>
                            <h4>Field Data App</h4>
                            <p>Patwari and SIA teams record land details, GPS points, and upload photos on-site — even offline.</p>
                            <a href="#" class="arrow">Learn more <i class="fa fa-arrow-right"/></a>
                        </div>
                        <div class="bhu-feature">
                            <div class="ico"><i class="fa fa-file-alt"/></div>
                            <h4>Digital Forms</h4>
                            <p>Seamless creation and approval workflows for Sections 4, 7, 8, 11, 15, and 19.</p>
                            <a href="#" class="arrow">Learn more <i class="fa fa-arrow-right"/></a>
                        </div>
                        <div class="bhu-feature">
                            <div class="ico"><i class="fa fa-file-signature"/></div>
                            <h4>Smart PDF &amp; E-Sign</h4>
                            <p>Instant generation and digital signing of official notifications and reports.</p>
                            <a href="#" class="arrow">Learn more <i class="fa fa-arrow-right"/></a>
                        </div>
                        <div class="bhu-feature">
                            <div class="ico"><i class="fa fa-chart-line"/></div>
                            <h4>Live Dashboard</h4>
                            <p>Track acquisition progress and parcel status across all projects in real time.</p>
                            <a href="#" class="arrow">Learn more <i class="fa fa-arrow-right"/></a>
                        </div>
                        <div class="bhu-feature">
                            <div class="ico"><i class="fa fa-shield-alt"/></div>
                            <h4>Role-Based Access</h4>
                            <p>Secure logins for Collector, SDM, Tahsildar, RI, Patwari &amp; SIA teams.</p>
                            <a href="#" class="arrow">Learn more <i class="fa fa-arrow-right"/></a>
                        </div>
                        <div class="bhu-feature">
                            <div class="ico"><i class="fa fa-chart-bar"/></div>
                            <h4>Analytics &amp; Reports</h4>
                            <p>Insights with project-wise and section-wise monitoring dashboards and exports.</p>
                            <a href="#" class="arrow">Learn more <i class="fa fa-arrow-right"/></a>
                        </div>
                    </div>
                </div>
            </section>

            <!-- ============================================================
                 WHY CHOOSE - Image cards
                 ============================================================ -->
            <section class="bhu-why">
                <div class="bhu-why-inner">
                    <div class="bhu-sec-head">
                        <span class="tag">Our Promise</span>
                        <h2>Why choose BHUARJAN?</h2>
                        <p>Four core pillars that make Bhuarjan the trusted choice for land administration.</p>
                    </div>
                    <div class="bhu-why-grid">
                        <div class="bhu-why-card">
                            <img class="wi-img" src="/bhuarjan_web/static/src/img/efficiancy.webp" alt="Efficiency"/>
                            <h4>Efficiency</h4>
                            <p>"Streamlines workflow and reduces manual effort across all departments."</p>
                        </div>
                        <div class="bhu-why-card">
                            <img class="wi-img" src="/bhuarjan_web/static/src/img/transparency.webp" alt="Transparency"/>
                            <h4>Transparency</h4>
                            <p>"Every process is fully traceable through immutable digital records."</p>
                        </div>
                        <div class="bhu-why-card">
                            <img class="wi-img" src="/bhuarjan_web/static/src/img/timeliness.webp" alt="Timeliness"/>
                            <h4>Timeliness</h4>
                            <p>"Real-time progress visibility ensures no delays across all stages."</p>
                        </div>
                        <div class="bhu-why-card">
                            <img class="wi-img" src="/bhuarjan_web/static/src/img/colaboration.webp" alt="Collaboration"/>
                            <h4>Collaboration</h4>
                            <p>"Seamless coordination between field teams and administration."</p>
                        </div>
                    </div>
                </div>
            </section>

            <!-- ============================================================
                 INSIGHTS
                 ============================================================ -->
            <section class="bhu-insights">
                <div class="bhu-insights-inner">
                    <div class="bhu-insights-content">
                        <span class="tag">Real-Time Insights</span>
                        <h2>From the field to the Collector's desk — instantly.</h2>
                        <div class="bhu-insights-list">
                            <div class="item">
                                <div class="ico"><i class="fa fa-mobile-alt"/></div>
                                <div>
                                    <strong>On-Ground Collection</strong>
                                    <p>Patwaris and SIA teams record land details, GPS points, and photos from the field — even offline.</p>
                                </div>
                            </div>
                            <div class="item">
                                <div class="ico"><i class="fa fa-tachometer-alt"/></div>
                                <div>
                                    <strong>Central Dashboard</strong>
                                    <p>Collectors and officials view project progress, approvals, and compensation status in real time.</p>
                                </div>
                            </div>
                            <div class="item">
                                <div class="ico"><i class="fa fa-bell"/></div>
                                <div>
                                    <strong>Automated Alerts</strong>
                                    <p>Instant notifications for pending approvals, expiring deadlines, and escalation triggers.</p>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="bhu-insights-visual">
                        <img src="/bhuarjan_web/static/src/img/land_management.jpg"
                             alt="BHUARJAN Dashboard"/>
                        <div class="bhu-insights-stat-card">
                            <div class="ico"><i class="fa fa-arrow-trend-up"/></div>
                            <div>
                                <div class="num">+ 47%</div>
                                <div class="lbl">Faster turnaround</div>
                            </div>
                        </div>
                    </div>
                </div>
            </section>

            <!-- ============================================================
                 ACQUISITION TIMELINE
                 ============================================================ -->
            <section class="bhu-roadmap">
                <div class="bhu-roadmap-inner">
                    <div class="bhu-sec-head">
                        <span class="tag">Execution Timeline</span>
                        <h2>End-to-end statutory acquisition timeline</h2>
                        <p>Track every core stage from survey entry to award and payment in one continuous flow.</p>
                    </div>

                    <div class="bhu-roadmap-wrap">
                        <div class="bhu-roadmap-track">
                            <div class="bhu-roadmap-step done">
                                <div class="dot"><i class="fa fa-check"/></div>
                                <h5>Survey</h5>
                                <p>Form 10</p>
                            </div>
                            <div class="bhu-roadmap-step pending">
                                <div class="dot">2</div>
                                <h5>SIA</h5>
                                <p>Team &amp; report</p>
                            </div>
                            <div class="bhu-roadmap-step done">
                                <div class="dot"><i class="fa fa-check"/></div>
                                <h5>Sec 4</h5>
                                <p>Notification</p>
                            </div>
                            <div class="bhu-roadmap-step pending">
                                <div class="dot">4</div>
                                <h5>Expert</h5>
                                <p>Committee</p>
                            </div>
                            <div class="bhu-roadmap-step current">
                                <div class="dot">5</div>
                                <h5>Sec 8</h5>
                                <p>Govt decision</p>
                            </div>
                            <div class="bhu-roadmap-step pending">
                                <div class="dot">6</div>
                                <h5>Sec 11</h5>
                                <p>Preliminary</p>
                            </div>
                            <div class="bhu-roadmap-step pending">
                                <div class="dot">7</div>
                                <h5>Sec 15</h5>
                                <p>Objections</p>
                            </div>
                            <div class="bhu-roadmap-step pending">
                                <div class="dot">8</div>
                                <h5>Sec 19</h5>
                                <p>Declaration</p>
                            </div>
                            <div class="bhu-roadmap-step pending">
                                <div class="dot">9</div>
                                <h5>Sec 21</h5>
                                <p>Notice</p>
                            </div>
                            <div class="bhu-roadmap-step done">
                                <div class="dot"><i class="fa fa-check"/></div>
                                <h5>Sec 23</h5>
                                <p>Award</p>
                            </div>
                            <div class="bhu-roadmap-step pending">
                                <div class="dot">11</div>
                                <h5>Payment</h5>
                                <p>Disbursement</p>
                            </div>
                        </div>
                        <div class="bhu-roadmap-note">
                            <i class="fa fa-circle-info"/> Status colors: <strong>Green</strong> completed, <strong>Brown</strong> active, <strong>Grey</strong> pending.
                        </div>
                    </div>
                </div>
            </section>

            <!-- ============================================================
                 STATS
                 ============================================================ -->
            <section class="bhu-stats">
                <div class="bhu-stats-inner">
                    <div class="bhu-stat-item">
                        <h3><span data-count="120" data-suffix="+">120+</span></h3>
                        <p>Projects Managed</p>
                    </div>
                    <div class="bhu-stat-item">
                        <h3><span data-count="5000" data-suffix="+">5,000+</span></h3>
                        <p>Land Parcels Processed</p>
                    </div>
                    <div class="bhu-stat-item">
                        <h3><span data-count="200" data-suffix="+">200+</span></h3>
                        <p>Government Users</p>
                    </div>
                    <div class="bhu-stat-item">
                        <h3><span data-count="99" data-suffix="%">99%</span></h3>
                        <p>Platform Uptime</p>
                    </div>
                </div>
            </section>

            <!-- ============================================================
                 CTA
                 ============================================================ -->
            <section class="bhu-cta">
                <div class="bhu-cta-inner">
                    <h2>Ready to digitise your district?</h2>
                    <p>Join the leading administration using Bhuarjan to deliver faster, fairer, and more transparent land governance.</p>
                    <a href="/contact" class="bhu-btn primary">
                        Talk to our team <i class="fa fa-arrow-right"/>
                    </a>
                </div>
            </section>

            <!-- FOOTER -->
            <t t-call="bhuarjan_web.footer"/>
        </t>
    </template>

    <!-- ============================================================
         FEATURES PAGE
         ============================================================ -->
    <template id="features_page" name="Bhuarjan – Features">
        <t t-call="website.layout">
            <t t-set="no_header" t-value="1"/>
            <t t-set="no_footer" t-value="1"/>
            <t t-set="head">
                <link rel="stylesheet" type="text/css"
                      t-att-href="'/bhuarjan_web/static/src/css/bhuarjan_website.css'"/>
                <link rel="stylesheet"
                      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"/>
                <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&amp;display=swap"
                      rel="stylesheet"/>
            </t>

            <t t-call="bhuarjan_web.navbar"/>

            <section class="bhu-features-hero">
                <span class="tag">Platform Capabilities</span>
                <h1>Features across every acquisition stage</h1>
                <p>
                    BHUARJAN digitises survey, notifications, objections, awards, and payment workflows
                    with audit trails and report-ready documentation.
                </p>
            </section>

            <section class="bhu-features-grid-wrap">
                <div class="bhu-features-grid">
                    <article class="bhu-feature-card">
                        <div class="bhu-feature-card-head">
                            <div class="bhu-feature-ico"><i class="fa fa-map-marked-alt"/></div>
                            <span class="bhu-feature-module">Survey Module</span>
                        </div>
                        <h3>Project Setup &amp; Land Survey</h3>
                        <p>Configure projects, villages, and parcel records with field-level tracking and verified ownership details.</p>
                        <ul class="bhu-feature-points">
                            <li>Mobile-ready field data capture</li>
                            <li>Khasra, owner, and geo details in one flow</li>
                        </ul>
                    </article>
                    <article class="bhu-feature-card">
                        <div class="bhu-feature-card-head">
                            <div class="bhu-feature-ico"><i class="fa fa-bullhorn"/></div>
                            <span class="bhu-feature-module">Notification Module</span>
                        </div>
                        <h3>Section 4 Notification</h3>
                        <p>Generate and monitor preliminary notifications with date-based status, workflow approvals, and digital traceability.</p>
                        <ul class="bhu-feature-points">
                            <li>Automated sequence and document generation</li>
                            <li>Approval-ready digital workflow</li>
                        </ul>
                    </article>
                    <article class="bhu-feature-card">
                        <div class="bhu-feature-card-head">
                            <div class="bhu-feature-ico"><i class="fa fa-gavel"/></div>
                            <span class="bhu-feature-module">Objection Module</span>
                        </div>
                        <h3>Section 11 &amp; Section 15 Processing</h3>
                        <p>Handle impact details, objection intake, hearing actions, and resolution outcomes from one structured dashboard.</p>
                        <ul class="bhu-feature-points">
                            <li>Hearing and resolution tracking</li>
                            <li>Transparent objection lifecycle</li>
                        </ul>
                    </article>
                    <article class="bhu-feature-card">
                        <div class="bhu-feature-card-head">
                            <div class="bhu-feature-ico"><i class="fa fa-file-invoice-dollar"/></div>
                            <span class="bhu-feature-module">Award Module</span>
                        </div>
                        <h3>Section 19, Award &amp; Compensation</h3>
                        <p>Drive final notification, award generation, beneficiary validation, and compensation calculations with ready reports.</p>
                        <ul class="bhu-feature-points">
                            <li>Land, tree, and asset compensation support</li>
                            <li>Consolidated and R&amp;R output formats</li>
                        </ul>
                    </article>
                    <article class="bhu-feature-card">
                        <div class="bhu-feature-card-head">
                            <div class="bhu-feature-ico"><i class="fa fa-user-shield"/></div>
                            <span class="bhu-feature-module">Access Control</span>
                        </div>
                        <h3>Approvals &amp; Role-Based Controls</h3>
                        <p>Enable Patwari, RI, Tehsildar, SDM, and Collector level actions with strict permission and approval routing.</p>
                        <ul class="bhu-feature-points">
                            <li>Role-wise menu and state transitions</li>
                            <li>Full audit trail of actions</li>
                        </ul>
                    </article>
                    <article class="bhu-feature-card">
                        <div class="bhu-feature-card-head">
                            <div class="bhu-feature-ico"><i class="fa fa-chart-line"/></div>
                            <span class="bhu-feature-module">Dashboard Module</span>
                        </div>
                        <h3>Dashboards &amp; Monitoring</h3>
                        <p>Track project progress, timeline bottlenecks, and pending actions through district and department dashboards.</p>
                        <ul class="bhu-feature-points">
                            <li>Live project and section monitoring</li>
                            <li>Decision-ready KPI cards</li>
                        </ul>
                    </article>
                    <article class="bhu-feature-card">
                        <div class="bhu-feature-card-head">
                            <div class="bhu-feature-ico"><i class="fa fa-folder-open"/></div>
                            <span class="bhu-feature-module">Document Vault</span>
                        </div>
                        <h3>Document &amp; Template Management</h3>
                        <p>Store, manage, and retrieve official files, templates, and signed outputs with searchable metadata.</p>
                        <ul class="bhu-feature-points">
                            <li>Centralized legal document repository</li>
                            <li>Standardized export-ready templates</li>
                        </ul>
                    </article>
                    <article class="bhu-feature-card">
                        <div class="bhu-feature-card-head">
                            <div class="bhu-feature-ico"><i class="fa fa-cogs"/></div>
                            <span class="bhu-feature-module">Master Data</span>
                        </div>
                        <h3>Master Configuration Engine</h3>
                        <p>Manage districts, tehsils, villages, rates, tree masters, sections, and reusable reference masters centrally.</p>
                        <ul class="bhu-feature-points">
                            <li>Consistent values across all modules</li>
                            <li>Fast onboarding for new projects</li>
                        </ul>
                    </article>
                </div>
            </section>

            <section class="bhu-pdf-shots">
                <div class="bhu-pdf-head">
                    <h2>PDF Screenshots</h2>
                    <p>Sample output views used for review and department communication.</p>
                </div>
                <div class="bhu-pdf-grid">
                    <article class="bhu-pdf-card">
                        <img src="/bhuarjan_web/static/src/img/dashboard_mockup.jpg" alt="Section report PDF preview"/>
                        <div class="meta">
                            <h4>Section Workflow Summary</h4>
                            <p>Overview snapshot for project progress and section-wise status.</p>
                        </div>
                    </article>
                    <article class="bhu-pdf-card">
                        <img src="/bhuarjan_web/static/src/img/hero_aerial.jpg" alt="Award statement PDF preview"/>
                        <div class="meta">
                            <h4>Award Statement Preview</h4>
                            <p>Representative format for award and compensation sheets.</p>
                        </div>
                    </article>
                    <article class="bhu-pdf-card">
                        <img src="/bhuarjan_web/static/src/img/land_management.jpg" alt="Notification order PDF preview"/>
                        <div class="meta">
                            <h4>Notification Order Preview</h4>
                            <p>Template-style preview for downloadable notification documents.</p>
                        </div>
                    </article>
                </div>
            </section>

            <t t-call="bhuarjan_web.footer"/>
        </t>
    </template>

    <!-- ============================================================
         CONTACT PAGE
         ============================================================ -->
    <template id="contact_page" name="Bhuarjan – Contact Us">
        <t t-call="website.layout">
            <t t-set="no_header" t-value="1"/>
            <t t-set="no_footer" t-value="1"/>
            <t t-set="head">
                <link rel="stylesheet" type="text/css"
                      t-att-href="'/bhuarjan_web/static/src/css/bhuarjan_website.css'"/>
                <link rel="stylesheet"
                      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"/>
                <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&amp;display=swap"
                      rel="stylesheet"/>
            </t>

            <t t-call="bhuarjan_web.navbar"/>

            <section class="bhu-contact-hero">
                <span class="tag">We'd love to hear from you</span>
                <h1>Get in touch</h1>
                <p>Questions, demo requests, or partnership enquiries — our team is here to help.</p>
            </section>

            <div class="bhu-contact-body">
                <div class="bhu-contact-info">
                    <h3>Reach out</h3>
