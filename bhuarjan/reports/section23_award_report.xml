                    <div>विभाग -</div>
                </td>
                <td width="20%" style="border:none !important; text-align:center; vertical-align:top; padding:3px 2px; font-size:10px; line-height:1.4; color:#000; font-family:'Noto Sans Devanagari','Mangal','Arial Unicode MS','DejaVu Sans',sans-serif;">
                    <div>(हस्ताक्षर)</div>
                    <div style="margin-top:8px;">&#160;</div>
                    <div>नाम -</div>
                    <div>पदनाम -</div>
                    <div>विभाग -</div>
                </td>
            </tr>
        </table>
    </template>

    <!-- Custom external layout for section23 award report -->
    <template id="section23_award_external_layout">
        <!-- Custom Header - repeats on every page -->
        <div class="header o_clearfix" style="width:100%; background:#fff; padding:0; margin:0; border:none; height:1px; overflow:hidden;">
            <div style="font-size:1px; color:#fff;">.</div>
        </div>
        <!-- Custom Footer - repeats on every page -->
        <div class="footer o_standard_footer" style="width:100%; background:#fff; border-top:2px solid #000; padding:4px 8px; -webkit-print-color-adjust:exact; print-color-adjust:exact;">
            <!-- Style inside footer div so it is included in wkhtml footer-html file -->
            <style>
                * { font-family: 'Noto Sans Devanagari', 'Mangal', 'Arial Unicode MS', 'DejaVu Sans', sans-serif !important; color: #000 !important; }
                .s23-footer-wrap { width: 100%; }
                .s23-footer-wrap td { border: none !important; width: 20%; text-align: center; vertical-align: top; padding: 3px 2px; font-size: 10px; line-height: 1.4; }
                .s23-sig-label { font-size: 10px; font-weight: 700; margin-top: 6px; }
            </style>
            <t t-call="bhuarjan.section23_signature_block"/>
        </div>
        <!-- Body content slot -->
        <div class="article o_report_layout_standard"
             t-att-data-oe-model="o and o._name"
             t-att-data-oe-id="o and o.id"
             style="margin-top: 0;">
            <t t-out="0"/>
        </div>
    </template>

    <template id="section23_award_report">
        <t t-call="web.html_container">
            <meta charset="utf-8"/>
            <t t-foreach="docs" t-as="o">
                <t t-set="land_data" t-value="o.get_land_compensation_data()"/>
                <t t-set="land_groups" t-value="o.get_land_compensation_grouped_data()"/>
                <t t-set="tree_data" t-value="o.get_tree_compensation_data()"/>
                <t t-set="asset_data" t-value="o.get_structure_compensation_data()"/>
                <t t-set="tree_groups" t-value="o.get_tree_compensation_grouped_data()"/>
                <t t-set="asset_groups" t-value="o.get_structure_compensation_grouped_data()"/>
                <t t-set="award_headers" t-value="o.get_award_header_constants()"/>
                <t t-set="s23_sale_sort_rate" t-value="o.avg_three_year_sales_sort_rate if o._name == 'bhu.section23.award' else 0.0"/>
                <t t-call="bhuarjan.report_common_styles"/>
                <t t-call="bhuarjan.section23_award_report_styles"/>
                <t t-set="base_url" t-value="o.env['ir.config_parameter'].sudo().get_param('web.base.url')"/>
                <t t-set="s23_scope" t-value="o.env.context.get('s23_pdf_scope', 'all')"/>
                <t t-set="show_land" t-value="s23_scope in ('all', 'land')"/>
                <t t-set="show_tree" t-value="s23_scope in ('all', 'tree')"/>
                <t t-set="show_asset" t-value="s23_scope in ('all', 'asset')"/>
                <t t-call="bhuarjan.section23_award_external_layout">

                    <style>
                        @page {
                            margin-top: 0.8cm;
                            margin-bottom: 5.5cm;
                            margin-left: 0.5cm;
                            margin-right: 0.5cm;
                        }
                    </style>

                    <!-- Part 1 (Ka) - LAND COMPENSATION -->
                    <div t-if="show_land" class="page section23-award-section" style="padding: 10px;">
                        <table class="section23-land-table" border="1" rules="all" style="border-collapse:collapse; width:100%;">
                            <thead>
                                <tr>
                                    <th colspan="20" style="border:none !important; box-shadow:none !important; background:#fff !important; padding:0 0 4px 0 !important;">
                                        <div style="text-align:center; color:#000; font-family:'Noto Sans Devanagari','Mangal','Arial Unicode MS','DejaVu Sans',sans-serif;">
                                            <div style="margin-bottom:4px;">
                                                <img src="/bhuarjan/static/img/logo.png" alt="Logo" style="height:40px; width:40px; object-fit:contain;"/>
                                            </div>
                                            <div style="font-size:15px; font-weight:700; color:#000;">अर्जित भूमि का मुआवजा प्रपत्र</div>
                                            <div style="font-size:10px; color:#000; margin-top:2px;">
                                                मूँ-अर्जन प्रकरण क्रमांक <span t-esc="o.name or ''"/> /
                                                ग्राम-<span t-esc="o.village_id.name if o.village_id else ''"/>&#160;
                                                प.ह.नं.-<span t-esc="o.project_id.name if o.project_id else ''"/>&#160;
                                                तहसील-<span t-esc="o.village_id.tehsil_id.name if o.village_id and o.village_id.tehsil_id else ''"/>&#160;
                                                जिला-<span t-esc="o.village_id.district_id.name if o.village_id and o.village_id.district_id else ''"/>
                                            </div>
                                            <div style="font-size:10px; font-weight:700; color:#000; margin-top:1px;">
                                                विगत तीन वर्षों का औसत बिक्री छांट दर : <span t-esc="o.format_indian_number(s23_sale_sort_rate or 0.0, 4)"/>
                                            </div>
                                            <div style="text-align:right; font-size:12px; font-weight:bold; margin-top:4px;">
                                                <span t-esc="award_headers['sections']['land_sheet_label']"/>
                                            </div>
                                        </div>
                                    </th>
                                </tr>
                                <tr>
                                    <th rowspan="2" style="border: 1px solid #000 !important; background-color: #e9ecef;"><span t-esc="award_headers['pdf']['land_headers']['rowspan_1']"/></th>
                                    <th rowspan="2" style="width: 120px; border: 1px solid #000 !important; background-color: #e9ecef;"><span t-esc="award_headers['pdf']['land_headers']['rowspan_2']"/></th>
                                    <th colspan="2" style="border: 1px solid #000 !important; background-color: #e9ecef;"><span t-esc="award_headers['pdf']['land_headers']['group_held']"/></th>
                                    <th colspan="2" style="border: 1px solid #000 !important; background-color: #e9ecef;"><span t-esc="award_headers['pdf']['land_headers']['group_acquired']"/></th>
                                    <th rowspan="2" style="border: 1px solid #000 !important; background-color: #e9ecef;"><span t-esc="award_headers['pdf']['land_headers']['sub_7']"/></th>
                                    <th colspan="3" style="border: 1px solid #000 !important; background-color: #e9ecef;"><span t-esc="award_headers['pdf']['land_headers']['group_main_road']"/></th>
                                    <th rowspan="2" style="border: 1px solid #000 !important; background-color: #e9ecef;"><span t-esc="award_headers['pdf']['land_headers']['col_11']"/></th>
                                    <th rowspan="2" style="border: 1px solid #000 !important; background-color: #e9ecef;"><span t-esc="award_headers['pdf']['land_headers']['col_12']"/></th>
                                    <th rowspan="2" style="border: 1px solid #000 !important; background-color: #e9ecef;"><span t-esc="award_headers['pdf']['land_headers']['col_13']"/></th>
                                    <th rowspan="2" style="border: 1px solid #000 !important; background-color: #e9ecef;"><span t-esc="award_headers['pdf']['land_headers']['col_14']"/></th>
                                    <th rowspan="2" style="border: 1px solid #000 !important; background-color: #e9ecef;"><span t-esc="award_headers['pdf']['land_headers']['col_15']"/>
                                        <span class="award-hdr-note">गुणांक 14 बाजार मूल्य 100% जोड़ें</span>
                                    </th>
                                    <th rowspan="2" style="border: 1px solid #000 !important; background-color: #e9ecef;">
                                        <span t-esc="award_headers['pdf']['land_headers']['col_16']"/><br/>
                                        <span t-esc="award_headers['pdf']['land_headers']['col_16_from']"/><br/>
                                        <span t-esc="award_headers['pdf']['land_headers']['col_16_to']"/>
                                    </th>
                                    <th rowspan="2" style="border: 1px solid #000 !important; background-color: #e9ecef;"><span t-esc="award_headers['pdf']['land_headers']['col_17']"/>
                                        <span class="award-hdr-note">यदि 6,8,17 एवं 18 में से देय</span>
                                        <span class="award-hdr-note">मुआवजा राशि</span>
                                    </th>
                                    <th rowspan="2" style="width: 9%; border: 1px solid #000 !important; background-color: #e9ecef;"><span t-esc="award_headers['pdf']['land_headers']['col_18']"/></th>
                                    <th rowspan="2" style="border: 1px solid #000 !important; background-color: #e9ecef;"><span t-esc="award_headers['pdf']['land_headers']['col_19']"/></th>
                                    <th rowspan="2" style="border: 1px solid #000 !important; background-color: #e9ecef;"><span t-esc="award_headers['pdf']['land_headers']['col_20']"/></th>
                                </tr>
                                <tr>
                                    <th style="border: 1px solid #000 !important; background-color: #e9ecef;"><span t-esc="award_headers['pdf']['land_headers']['sub_3']"/></th>
                                    <th style="border: 1px solid #000 !important; background-color: #e9ecef;"><span t-esc="award_headers['pdf']['land_headers']['sub_4']"/></th>
                                    <th style="border: 1px solid #000 !important; background-color: #e9ecef;"><span t-esc="award_headers['pdf']['land_headers']['sub_5']"/></th>
                                    <th style="border: 1px solid #000 !important; background-color: #e9ecef;"><span t-esc="award_headers['pdf']['land_headers']['sub_6']"/></th>
                                    <th style="border: 1px solid #000 !important; background-color: #e9ecef;"><span t-esc="award_headers['pdf']['land_headers']['sub_8']"/></th>
                                    <th style="border: 1px solid #000 !important; background-color: #e9ecef;"><span t-esc="award_headers['pdf']['land_headers']['sub_9']"/></th>
                                    <th style="border: 1px solid #000 !important; background-color: #e9ecef;"><span t-esc="award_headers['pdf']['land_headers']['sub_10']"/></th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-set="serial" t-value="1"/>
                                <t t-foreach="land_groups" t-as="group">
                                    <t t-set="group_lines" t-value="group.get('lines')"/>
                                    <t t-set="line_count" t-value="len(group_lines)"/>
                                    <t t-foreach="group_lines" t-as="land">
                                        <tr>
                                            <td t-if="land_index == 0" t-att-rowspan="line_count" style="text-align: center; font-weight: bold; border: 1px solid #000 !important;" t-esc="serial"/>
                                            <td t-if="land_index == 0" t-att-rowspan="line_count" style="border: 1px solid #000 !important;">
                                                <span t-esc="group.get('landowner_name', '')"/><br/>
                                                <t t-if="group.get('father_name')">पिता/पति: <span t-esc="group.get('father_name')"/></t>
                                            </td>
                                            <td style="text-align: center; border: 1px solid #000 !important;" t-esc="land.get('khasra', '')"/>
                                            <td style="text-align: right; border: 1px solid #000 !important;" t-esc="o.format_indian_number(land.get('original_area', 0.0), 3)"/>
                                            <td style="text-align: center; border: 1px solid #000 !important;" t-esc="land.get('khasra', '')"/>
                                            <td style="text-align: right; border: 1px solid #000 !important;" t-esc="o.format_indian_number(land.get('acquired_area', 0.0), 3)"/>
                                            <td style="text-align: center; border: 1px solid #000 !important;">
                                                <t t-set="dfm" t-value="land.get('distance_from_main_road') or 0.0"/>
                                                <t t-if="dfm and land.get('is_within_distance')">
                                                    <span t-att-style="'color:#1b8f3a;font-weight:700;' if land.get('is_within_distance') else 'color:#c62828;font-weight:700;'">
                                                        <span t-esc="'%.2f' % dfm"/> m
                                                    </span>
                                                </t>
                                                <t t-else="">
                                                    <span t-att-style="'color:#1b8f3a;font-weight:700;' if land.get('is_within_distance') else 'color:#c62828;font-weight:700;'"
                                                          t-esc="'हाँ' if land.get('is_within_distance') else 'नहीं'"/>
                                                </t>
                                            </td>
                                            <td style="text-align: center; border: 1px solid #000 !important;">
                                                <t t-if="land.get('is_within_distance')">
                                                    <span style="font-weight:700;">NA</span>
                                                </t>
                                                <t t-else="">
                                                    <span t-att-style="'color:#1b8f3a;font-weight:700;' if land.get('irrigated') else 'color:#c62828;font-weight:700;'"
                                                          t-esc="'हाँ' if land.get('irrigated') else 'नहीं'"/>
                                                </t>
                                            </td>
                                            <td style="text-align: center; border: 1px solid #000 !important;">
                                                <t t-if="land.get('is_within_distance')">
                                                    <span style="font-weight:700;">NA</span>
                                                </t>
                                                <t t-else="">
                                                    <span t-att-style="'color:#1b8f3a;font-weight:700;' if land.get('unirrigated') else 'color:#c62828;font-weight:700;'"
                                                          t-esc="'हाँ' if land.get('unirrigated') else 'नहीं'"/>
                                                </t>
                                            </td>
                                            <td style="text-align: center; border: 1px solid #000 !important;">
                                                <t t-if="land.get('is_within_distance')">
                                                    <span style="font-weight:700;">NA</span>
                                                </t>
                                                <t t-else="">
                                                    <span t-att-style="'color:#1b8f3a;font-weight:700;' if land.get('is_diverted') else 'color:#c62828;font-weight:700;'"
                                                          t-esc="'हाँ' if land.get('is_diverted') else 'नहीं'"/>
                                                </t>
                                            </td>
                                            <td style="text-align: right; border: 1px solid #000 !important;" t-esc="o.format_indian_number(s23_sale_sort_rate or 0.0, 4)"/>
                                            <td style="text-align: right; border: 1px solid #000 !important;" t-esc="o.format_indian_number(land.get('guide_line_rate', 0.0), 0)"/>
                                            <td style="text-align: right; border: 1px solid #000 !important;" t-esc="o.format_indian_number(land.get('basic_value', 0.0), 0)"/>
                                            <td style="text-align: right; border: 1px solid #000 !important;" t-esc="o.format_indian_number(land.get('market_value', 0.0), 0)"/>
                                            <td style="text-align: right; border: 1px solid #000 !important;" t-esc="o.format_indian_number(land.get('solatium', 0.0), 0)"/>
