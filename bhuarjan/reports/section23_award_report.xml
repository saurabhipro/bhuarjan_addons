<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Section 23 Award Report Action -->
        <record id="action_report_section23_award" model="ir.actions.report">
            <field name="name">Section 23 Award / धारा 23 अवार्ड</field>
            <field name="model">bhu.section23.award</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">bhuarjan.section23_award_report</field>
            <field name="report_file">bhuarjan.section23_award_report</field>
            <field name="print_report_name">'Section23_Award_%s' % (object.village_id.name or 'Village')</field>
            <field name="paperformat_id" ref="bhuarjan.bhuarjan_section_23_award_paper_format"/>
        </record>
    </data>

    <template id="section23_award_report_styles">
        <style>
            .container {
                font-family: 'Noto Sans Devanagari', 'Nirmala UI', 'Mangal', 'Lohit Devanagari', 'DejaVu Sans', sans-serif;
            }
            .hindi {
                font-family: 'Noto Sans Devanagari', 'Nirmala UI', 'Mangal', 'Lohit Devanagari', 'DejaVu Sans', sans-serif;
            }
            .header-text { color: #1a237e; border-bottom: 2px solid #1a237e; }
            .page { position: relative; }
            .container img { border: none !important; outline: none !important; box-shadow: none !important; }
            /* One sheet per page: land, then trees, then assets (wkhtmltopdf) */
            .section23-award-section + .section23-award-section {
                page-break-before: always !important;
                break-before: page !important;
            }
            .letter_space { letter-spacing: 0.5px; }
            /* Explicitly protect header/footer tables from any border rules */
            .header table, .header table td, .header table th,
            .footer table, .footer table td, .footer table th,
            .section-signatures, .section-signatures td, .section-signatures th {
                border: none !important;
                background-color: transparent !important;
            }
            /* Scope ALL table/cell border rules to .page only — never touch header/footer tables */
            .page table {
                border-collapse: collapse !important;
                border-spacing: 0 !important;
                width: 100%;
                page-break-inside: auto;
                border: none !important;
                empty-cells: show !important;
            }
            .page thead { display: table-header-group !important; }
            .page tfoot { display: table-footer-group !important; }
            .page tr { page-break-inside: avoid; page-break-after: auto; }
            .page th {
                background-color: #f2f2f2;
                font-weight: bold;
                border: 1px solid #000 !important;
                border-top: 1px solid #000 !important;
                border-right: 1px solid #000 !important;
                border-bottom: 1px solid #000 !important;
                border-left: 1px solid #000 !important;
                box-shadow: inset 0 0 0 1px #000;
                outline: 1px solid #000 !important;
                outline-offset: -1px;
                padding: 4px;
                font-size: 10px;
            }
            .page td {
                border: 1px solid #000 !important;
                border-top: 1px solid #000 !important;
                border-right: 1px solid #000 !important;
                border-bottom: 1px solid #000 !important;
                border-left: 1px solid #000 !important;
                box-shadow: inset 0 0 0 1px #000;
                outline: 1px solid #000 !important;
                outline-offset: -1px;
                padding: 3px;
                font-size: 9px;
                vertical-align: middle;
            }
            .award-hdr-note { font-size: 8px; line-height: 1.15; font-weight: 700; display: block; margin-top: 2px; color: #222; }
            .total-row { background-color: #ffd54f; font-weight: bold; }
            /* Signature table in footer — no cell borders */
            .section-signatures { width: 100%; margin-top: 6px; border: none !important; border-collapse: collapse; }
            .section-signatures td {
                border: none !important;
                width: 20%;
                text-align: center;
                vertical-align: top;
                padding: 4px;
                font-size: 10px;
                line-height: 1.35;
            }
            .section-signatures .sig-title {
                font-weight: bold;
                margin-top: 10px;
            }
            .section23-land-table {
                border-collapse: collapse !important;
                border-spacing: 0 !important;
                width: 100%;
                border: none !important;
            }
            .section23-land-table th,
            .section23-land-table td {
                box-sizing: border-box;
                border: 1px solid #000 !important;
            }
            .section23-land-table tbody tr > td:last-child { min-width: 3.5em; }
            .section23-award-section { box-sizing: border-box; }
            /* Reset article padding so tables span full page width */
            .article, .article.o_report_layout_standard {
                padding: 0 !important;
                margin: 0 !important;
                width: 100% !important;
                box-sizing: border-box !important;
            }
            /* High-specificity cell borders to defeat any Odoo reset CSS */
            html body .page table td {
                border: 1px solid #000 !important;
                border-top: 1px solid #000 !important;
                border-right: 1px solid #000 !important;
                border-bottom: 1px solid #000 !important;
                border-left: 1px solid #000 !important;
                outline: 1px solid #000 !important;
                outline-offset: -1px;
                padding: 3px !important;
            }
            html body .page table th {
                border: 1px solid #000 !important;
                border-top: 1px solid #000 !important;
                border-right: 1px solid #000 !important;
                border-bottom: 1px solid #000 !important;
                border-left: 1px solid #000 !important;
                outline: 1px solid #000 !important;
                outline-offset: -1px;
                padding: 4px !important;
            }
            html body table.section23-land-table td,
            html body table.section23-tree-table td,
            html body table.section23-asset-table td,
            html body table.section23-land-table th,
            html body table.section23-tree-table th,
            html body table.section23-asset-table th {
                border: 1px solid #000 !important;
                border-top: 1px solid #000 !important;
                border-right: 1px solid #000 !important;
                border-bottom: 1px solid #000 !important;
                border-left: 1px solid #000 !important;
                outline: 1px solid #000 !important;
                outline-offset: -1px;
            }
        </style>
    </template>

