<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Fully replace web.login content with a standalone clean template -->
    <template id="login_standalone_markup" inherit_id="web.login" priority="999">
        <xpath expr="//t[@t-call='web.login_layout']" position="replace">
            <t t-call="web.login_layout">
                <link rel="stylesheet" type="text/css"
                      href="/bhuarjan_web/static/src/css/bhuarjan_login.css"/>
                <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&amp;display=swap"
                      rel="stylesheet"/>
                <script type="text/javascript">
                    document.addEventListener('DOMContentLoaded', function () {
                        document.body.classList.add('bhu-login-body');
                    });
                </script>

                <div id="bhu-login-root">
                    <div class="bhu-login-logos">
                        <img src="/bhuarjan_web/static/src/img/bhuarjan_logo.png" alt="BHUARJAN logo" class="bhu-logo-left"/>
                        <div class="bhu-logo-divider"/>
                        <img src="/bhuarjan_web/static/src/img/chattisgarh_logo.png" alt="Chhattisgarh logo" class="bhu-logo-right"/>
                    </div>

                    <div class="bhu-login-head">
                        <h1>Login to account</h1>
                        <p>Access BHUARJAN secure portal</p>
                    </div>

                    <form class="oe_login_form" role="form" t-attf-action="/web/login" method="post"
                          onsubmit="this.action = '/web/login' + location.hash">
                        <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>

                        <div class="mb-3" t-if="databases and len(databases) &gt; 1">
                            <label for="db" class="col-form-label">Database</label>
                            <div class="input-group">
                                <input type="text" name="db" t-att-value="request.db" id="db" class="form-control"
                                       required="required" readonly="readonly"/>
                                <a role="button" href="/web/database/selector" class="btn btn-secondary">
                                    Select <i class="fa fa-database" role="img" aria-label="Database" title="Database"/>
                                </a>
                            </div>
                        </div>

                        <div class="mb-3 field-login">
                            <label for="login" class="form-label d-flex justify-content-between">Email</label>
                            <input type="text" placeholder="E-mail Address" name="login" t-att-value="login" id="login"
                                   class="form-control" required="required" autocapitalize="off" autocomplete="username"
                                   autofocus="autofocus"/>
                        </div>

                        <div class="mb-3">
                            <label for="password" class="form-label d-flex justify-content-between">Password</label>
                            <input type="password" placeholder="Password" name="password" id="password"
                                   class="form-control" required="required" autocomplete="current-password"
                                   maxlength="4096"/>
                        </div>

                        <p class="alert alert-danger" t-if="error" role="alert">
                            <t t-esc="error"/>
                        </p>
                        <p class="alert alert-success" t-if="message" role="status">
                            <t t-esc="message"/>
                        </p>

                        <div class="oe_login_buttons text-center gap-1 d-grid mb-1 pt-3">
                            <button type="submit" class="btn btn-primary">Log in</button>
                        </div>

                        <input type="hidden" name="type" value="password"/>
                        <input type="hidden" name="redirect" t-att-value="redirect or '/odoo'"/>
                    </form>

                    <div class="o_login_redirect_back">
                        <a href="/">← Back to BHUARJAN home</a>
                    </div>
                </div>
            </t>
        </xpath>
    </template>

</odoo>
