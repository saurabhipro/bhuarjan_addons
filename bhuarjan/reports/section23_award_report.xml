                                            </td>
                                            <td style="text-align: center;" t-esc="tree.get('land_khasra') or tree.get('khasra', '')"/>
                                            <td style="text-align: right;" t-esc="o.format_indian_number(tree.get('land_area_ha', 0.0), 4)"/>
