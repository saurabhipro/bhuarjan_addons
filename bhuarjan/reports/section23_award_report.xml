<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_common_styles">
        <style>
            .container {
                font-family: 'Noto Sans Devanagari', 'Nirmala UI', 'Mangal', 'Lohit Devanagari', 'DejaVu Sans', sans-serif;
            }
            .hindi {
                font-family: 'Noto Sans Devanagari', 'Nirmala UI', 'Mangal', 'Lohit Devanagari', 'DejaVu Sans', sans-serif;
            }
            .header-text { color: #1a237e; border-bottom: 2px solid #1a237e; }
            .watermark {
                position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%) rotate(-45deg);
                opacity: 0.1; font-size: 80px; color: #ccc; z-index: -1000; width: 100%; text-align: center;
            }
            .watermark img { width: 400px; height: auto; border: none !important; outline: none !important; box-shadow: none !important; }
            .container img { border: none !important; outline: none !important; box-shadow: none !important; }
            .letter_space { letter-spacing: 0.5px; }
            table { border-collapse: collapse; width: 100%; page-break-inside: auto; }
            tr { page-break-inside: avoid; page-break-after: auto; }
            th { background-color: #f2f2f2; font-weight: bold; border: 1px solid #000; padding: 4px; font-size: 10px; }
            td { border: 1px solid #000; padding: 3px; font-size: 9px; vertical-align: middle; }
            .award-hdr-note { font-size: 8px; line-height: 1.15; font-weight: 700; display: block; margin-top: 2px; color: #222; }
            .total-row { background-color: #e8eaf6; font-weight: bold; }
            .section-signatures { width: 100%; margin-top: 14px; border: none; }
            .section-signatures td {
                border: none;
                width: 20%;
                text-align: center;
                vertical-align: top;
                padding: 4px;
                font-size: 10px;
                line-height: 1.35;
            }
            .section-signatures .sig-title {
                font-weight: bold;
                margin-top: 18px;
            }
        </style>
    </template>

    <template id="section23_signature_block">
        <table class="section-signatures">
            <tr>
                <td>
                    <div>(हस्ताक्षर)</div>
                    <div class="sig-title">अपेक्षक निकाय के</div>
                    <div class="sig-title">अधिकृत प्रतिनिधि</div>
                    <div>नाम -</div>
                    <div>पदनाम -</div>
                </td>
                <td>
                    <div>(हस्ताक्षर)</div>
                    <div class="sig-title">तहसीलदार</div>
                    <div>नाम -</div>
                </td>
                <td>
                    <div>(हस्ताक्षर)</div>
                    <div class="sig-title">नायब तहसीलदार</div>
                    <div>नाम -</div>
                </td>
                <td>
                    <div>(हस्ताक्षर)</div>
                    <div class="sig-title">राजस्व निरीक्षक</div>
                    <div>नाम -</div>
                    <div>रा.नि.मं. -</div>
                </td>
                <td>
                    <div>(हस्ताक्षर)</div>
                    <div class="sig-title">अनुविभागीय अधिकारी(रा.) एवं</div>
                    <div class="sig-title">भू-अर्जन अधिकारी</div>
                    <div>रायगढ़ (छ.ग.)</div>
                </td>
            </tr>
        </table>
    </template>

    <template id="section23_award_report">
        <t t-call="web.html_container">
            <meta charset="utf-8"/>
            <t t-foreach="docs" t-as="o">
                <t t-set="land_data" t-value="o.get_land_compensation_data()"/>
                <t t-set="land_groups" t-value="o.get_land_compensation_grouped_data()"/>
                <t t-set="tree_data" t-value="o.get_tree_compensation_data()"/>
                <t t-set="asset_data" t-value="o.get_structure_compensation_data()"/>
                <t t-set="tree_groups" t-value="o.get_tree_compensation_grouped_data()"/>
                <t t-set="asset_groups" t-value="o.get_structure_compensation_grouped_data()"/>
                <t t-set="award_headers" t-value="o.get_award_header_constants()"/>
                <t t-call="bhuarjan.report_common_styles"/>

                <!-- Part 1 (Ka) - LAND COMPENSATION -->
                <div class="page" style="padding: 10px;">
                        <div class="watermark">
                             <t t-set="base_url" t-value="o.env['ir.config_parameter'].sudo().get_param('web.base.url')"/>
                             <img t-att-src="base_url + '/bhuarjan/static/img/logo.png'" alt="Logo Watermark"/>
                        </div>

                        <div style="text-align: right; font-size: 12px; font-weight: bold; margin-bottom: 5px;">
                            <span t-esc="award_headers['sections']['land_sheet_label']"/>
                        </div>

                        <div style="text-align: center; margin-bottom: 10px;">
                            <div style="margin-bottom: 6px;">
                                <img t-att-src="base_url + '/bhuarjan/static/img/logo.png'" alt="Logo" style="height: 44px; width: auto;"/>
                            </div>
                            <h2 style="margin: 0;"><span t-esc="award_headers['sections']['land_title']"/></h2>
                            <div style="font-size: 11px; margin-top: 5px;">
                                मूँ-अर्जन प्रकरण क्रमांक <span t-esc="o.name if o._name == 'bhu.section23.award' else 'Simulation'"/> / <span t-esc="o.award_document_filename if (o._name == 'bhu.section23.award' and o.award_document_filename) else 'अ-82/2022-23'"/>
                            </div>
                        </div>

                        <div style="text-align: center; font-size: 11px; margin-bottom: 10px; font-weight: bold;">
                            ग्राम-<span t-esc="o.village_id.name if o.village_id else ''"/> प.ह.नं.-<span t-esc="o.project_id.name if o.project_id else ''"/> रा.नि.मं.-<span t-esc="''"/> तहसील-<span t-esc="o.village_id.tehsil_id.name if o.village_id and o.village_id.tehsil_id else ''"/> जिला-<span t-esc="o.village_id.district_id.name if o.village_id and o.village_id.district_id else ''"/>
                        </div>

                        <table border="1">
                            <thead>
                                <tr>
                                    <th rowspan="2"><span t-esc="award_headers['pdf']['land_headers']['rowspan_1']"/></th>
                                    <th rowspan="2" style="width: 120px;"><span t-esc="award_headers['pdf']['land_headers']['rowspan_2']"/></th>
                                    <th colspan="2"><span t-esc="award_headers['pdf']['land_headers']['group_held']"/></th>
                                    <th colspan="2"><span t-esc="award_headers['pdf']['land_headers']['group_acquired']"/></th>
                                    <th rowspan="2"><span t-esc="award_headers['pdf']['land_headers']['sub_7']"/></th>
                                    <th colspan="3"><span t-esc="award_headers['pdf']['land_headers']['group_main_road']"/></th>
                                    <th rowspan="2"><span t-esc="award_headers['pdf']['land_headers']['col_11']"/></th>
                                    <th rowspan="2"><span t-esc="award_headers['pdf']['land_headers']['col_12']"/></th>
                                    <th rowspan="2"><span t-esc="award_headers['pdf']['land_headers']['col_13']"/></th>
                                    <th rowspan="2"><span t-esc="award_headers['pdf']['land_headers']['col_14']"/></th>
                                    <th rowspan="2"><span t-esc="award_headers['pdf']['land_headers']['col_15']"/>
                                        <span class="award-hdr-note">गुणांक 14 बाजार मूल्य 100% जोड़ें</span>
                                    </th>
                                    <th rowspan="2">
                                        <span t-esc="award_headers['pdf']['land_headers']['col_16']"/><br/>
                                        <span t-esc="award_headers['pdf']['land_headers']['col_16_from']"/><br/>
                                        <span t-esc="award_headers['pdf']['land_headers']['col_16_to']"/>
                                    </th>
                                    <th rowspan="2"><span t-esc="award_headers['pdf']['land_headers']['col_17']"/>
                                        <span class="award-hdr-note">यदि 6,8,17 एवं 18 में से देय</span>
                                        <span class="award-hdr-note">मुआवजा राशि</span>
                                    </th>
                                    <th rowspan="2" style="width: 9%;"><span t-esc="award_headers['pdf']['land_headers']['col_18']"/></th>
                                    <th rowspan="2"><span t-esc="award_headers['pdf']['land_headers']['col_19']"/></th>
                                    <th rowspan="2"><span t-esc="award_headers['pdf']['land_headers']['col_20']"/></th>
                                </tr>
                                <tr>
                                    <th><span t-esc="award_headers['pdf']['land_headers']['sub_3']"/></th>
                                    <th><span t-esc="award_headers['pdf']['land_headers']['sub_4']"/></th>
                                    <th><span t-esc="award_headers['pdf']['land_headers']['sub_5']"/></th>
                                    <th><span t-esc="award_headers['pdf']['land_headers']['sub_6']"/></th>
                                    <th><span t-esc="award_headers['pdf']['land_headers']['sub_8']"/></th>
                                    <th><span t-esc="award_headers['pdf']['land_headers']['sub_9']"/></th>
                                    <th><span t-esc="award_headers['pdf']['land_headers']['sub_10']"/></th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-set="serial" t-value="1"/>
                                <t t-foreach="land_groups" t-as="group">
                                    <t t-set="group_lines" t-value="group.get('lines')"/>
                                    <t t-set="line_count" t-value="len(group_lines)"/>
                                    <t t-foreach="group_lines" t-as="land">
                                        <tr>
                                            <td t-if="land_index == 0" t-att-rowspan="line_count" style="text-align: center; font-weight: bold;" t-esc="serial"/>
                                            <td t-if="land_index == 0" t-att-rowspan="line_count">
                                                <span t-esc="group.get('landowner_name', '')"/><br/>
                                                <t t-if="group.get('father_name')">पिता/पति: <span t-esc="group.get('father_name')"/></t>
                                            </td>
                                            <td style="text-align: center;" t-esc="land.get('khasra', '')"/>
                                            <td style="text-align: right;" t-esc="o.format_indian_number(land.get('original_area', 0.0), 3)"/>
                                            <td style="text-align: center;" t-esc="land.get('khasra', '')"/>
                                            <td style="text-align: right;" t-esc="o.format_indian_number(land.get('acquired_area', 0.0), 3)"/>
                                            <td style="text-align: center;">
                                                <t t-set="dfm" t-value="land.get('distance_from_main_road') or 0.0"/>
                                                <t t-if="dfm and land.get('is_within_distance')">
                                                    <span t-att-style="'color:#1b8f3a;font-weight:700;' if land.get('is_within_distance') else 'color:#c62828;font-weight:700;'">
                                                        <span t-esc="'%.2f' % dfm"/> m
                                                    </span>
                                                </t>
                                                <t t-else="">
                                                    <span t-att-style="'color:#1b8f3a;font-weight:700;' if land.get('is_within_distance') else 'color:#c62828;font-weight:700;'"
                                                          t-esc="'हाँ' if land.get('is_within_distance') else 'नहीं'"/>
                                                </t>
                                            </td>
                                            <td style="text-align: center;">
                                                <t t-if="land.get('is_within_distance')">
                                                    <span style="font-weight:700;">NA</span>
                                                </t>
                                                <t t-else="">
                                                    <span t-att-style="'color:#1b8f3a;font-weight:700;' if land.get('irrigated') else 'color:#c62828;font-weight:700;'"
                                                          t-esc="'हाँ' if land.get('irrigated') else 'नहीं'"/>
                                                </t>
                                            </td>
                                            <td style="text-align: center;">
                                                <t t-if="land.get('is_within_distance')">
                                                    <span style="font-weight:700;">NA</span>
                                                </t>
                                                <t t-else="">
                                                    <span t-att-style="'color:#1b8f3a;font-weight:700;' if land.get('unirrigated') else 'color:#c62828;font-weight:700;'"
                                                          t-esc="'हाँ' if land.get('unirrigated') else 'नहीं'"/>
                                                </t>
                                            </td>
                                            <td style="text-align: center;">
                                                <t t-if="land.get('is_within_distance')">
                                                    <span style="font-weight:700;">NA</span>
                                                </t>
                                                <t t-else="">
                                                    <span t-att-style="'color:#1b8f3a;font-weight:700;' if land.get('is_diverted') else 'color:#c62828;font-weight:700;'"
                                                          t-esc="'हाँ' if land.get('is_diverted') else 'नहीं'"/>
                                                </t>
                                            </td>
                                            <td style="text-align: center;">-</td>
                                            <td style="text-align: right;" t-esc="o.format_indian_number(land.get('guide_line_rate', 0.0), 0)"/>
                                            <td style="text-align: right;" t-esc="o.format_indian_number(land.get('basic_value', 0.0), 0)"/>
                                            <td style="text-align: right;" t-esc="o.format_indian_number(land.get('market_value', 0.0), 0)"/>
                                            <td style="text-align: right;" t-esc="o.format_indian_number(land.get('solatium', 0.0), 0)"/>
                                            <td style="text-align: right;" t-esc="o.format_indian_number(land.get('interest', 0.0), 0)"/>
                                            <td style="text-align: right; font-weight: bold;" t-esc="o.format_indian_number(land.get('total_compensation', 0.0), 0)"/>
                                            <td style="text-align: right;" t-esc="o.format_indian_number(land.get('rehab_policy_amount', 0.0), 0)"/>
                                            <td style="text-align: right;" t-esc="o.format_indian_number(land.get('paid_compensation', 0.0), 0)"/>
                                            <td t-esc="land.get('remark', '')"/>
                                        </tr>
                                    </t>
                                    <tr class="total-row">
                                        <td colspan="2" style="text-align: center; font-weight: bold;">कुल</td>
                                        <td style="text-align: center; font-weight: bold;" t-esc="group.get('khasra_count', 0)"/>
                                        <td style="text-align: right; font-weight: bold;" t-esc="o.format_indian_number(group.get('original_area', 0.0), 3)"/>
                                        <td style="text-align: center; font-weight: bold;" t-esc="group.get('khasra_count', 0)"/>
                                        <td style="text-align: right; font-weight: bold;" t-esc="o.format_indian_number(group.get('acquired_area', 0.0), 3)"/>
                                        <td style="text-align: center; font-weight: bold;">-</td>
                                        <td style="text-align: center; font-weight: bold;">-</td>
                                        <td style="text-align: center; font-weight: bold;">-</td>
                                        <td style="text-align: right; font-weight: bold;">-</td>
                                        <td style="text-align: right; font-weight: bold;">-</td>
                                        <td style="text-align: right; font-weight: bold;" t-esc="o.format_indian_number(group.get('basic_value', 0.0), 0)"/>
                                        <td style="text-align: right; font-weight: bold;" t-esc="o.format_indian_number(group.get('market_value', 0.0), 0)"/>
                                        <td style="text-align: right; font-weight: bold;" t-esc="o.format_indian_number(group.get('solatium', 0.0), 0)"/>
                                        <td style="text-align: right; font-weight: bold;" t-esc="o.format_indian_number(group.get('interest', 0.0), 0)"/>
                                        <td style="text-align: right; font-weight: bold;" t-esc="o.format_indian_number(group.get('total_compensation', 0.0), 0)"/>
                                        <td style="text-align: right; font-weight: bold;" t-esc="o.format_indian_number(group.get('rehab_policy_amount', 0.0), 0)"/>
                                        <td style="text-align: right; font-weight: bold;" t-esc="o.format_indian_number(group.get('paid_compensation', 0.0), 0)"/>
                                        <td></td>
                                    </tr>
                                    <t t-set="serial" t-value="serial + 1"/>
                                </t>
                                <t t-if="not land_groups">
                                    <tr>
                                        <td colspan="20" style="text-align: center; font-style: italic;">
                                            No land data available / भूमि डेटा उपलब्ध नहीं है (Blank)
                                        </td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                        <t t-call="bhuarjan.section23_signature_block"/>
                </div>

                <!-- Part 1 (Kh) - ASSET / STRUCTURE COMPENSATION -->
                <div class="page" style="padding: 10px;">
                            <div class="watermark">
                                 <t t-set="base_url" t-value="o.env['ir.config_parameter'].sudo().get_param('web.base.url')"/>
                                 <img t-att-src="base_url + '/bhuarjan/static/img/logo.png'" alt="Logo Watermark"/>
                            </div>

                            <div style="text-align: right; font-size: 12px; font-weight: bold; margin-bottom: 5px;">
                                <span t-esc="award_headers['sections']['asset_sheet_label']"/>
                            </div>

                            <div style="text-align: center; margin-bottom: 10px;">
                                <div style="margin-bottom: 6px;">
                                    <img t-att-src="base_url + '/bhuarjan/static/img/logo.png'" alt="Logo" style="height: 44px; width: auto;"/>
                                </div>
                                <h2 style="margin: 0;"><span t-esc="award_headers['sections']['asset_title']"/></h2>
                                <div style="font-size: 11px; margin-top: 5px;">
                                    मूँ-अर्जन प्रकरण क्रमांक <span t-esc="o.name if o._name == 'bhu.section23.award' else 'Simulation'"/> / <span t-esc="o.award_document_filename if (o._name == 'bhu.section23.award' and o.award_document_filename) else 'अ-82/2022-23'"/>
                                </div>
                            </div>

                            <div style="text-align: center; font-size: 11px; margin-bottom: 10px; font-weight: bold;">
                                ग्राम-<span t-esc="o.village_id.name if o.village_id else ''"/> प.ह.नं.-<span t-esc="o.project_id.name if o.project_id else ''"/> रा.नि.मं.-<span t-esc="''"/> तहसील-<span t-esc="o.village_id.tehsil_id.name if o.village_id and o.village_id.tehsil_id else ''"/> जिला-<span t-esc="o.village_id.district_id.name if o.village_id and o.village_id.district_id else ''"/>
                            </div>

                        <table border="1">
                                <thead>
                                    <tr>
                                        <th style="width: 30px;">1. <br/>क्र.</th>
                                        <th style="width: 150px;">2. <br/>भूमिस्वामी का नाम व पिता/पति का नाम</th>
                                        <th>3. <br/>खसरा</th>
                                        <th>4. <br/>रकबा</th>
                                        <th style="width: 100px;">5. <br/>परिसम्पत्ति का विवरण<br/>(1) मकान (2) कुआं (3) शेड (4) अन्य</th>
                                        <th>6. <br/>क्षेत्रफल</th>
                                        <th>7. <br/>बाजार मूल्य</th>
                                        <th>8. <br/>100% सोलेशियम</th>
                                        <th>9. <br/>12% ब्याज</th>
                                        <th>10. <br/>योग</th>
                                        <th>11. <br/>रिमार्क</th>
                                    </tr>
                                </thead>
                            <tbody>
                                <t t-set="serial" t-value="1"/>
                                <t t-foreach="asset_groups" t-as="group">
                                    <t t-set="group_lines" t-value="group.get('lines')"/>
                                    <t t-set="line_count" t-value="len(group_lines)"/>
                                    <t t-foreach="group_lines" t-as="asset">
                                        <tr>
                                            <td t-if="asset_index == 0" t-att-rowspan="line_count" style="text-align: center; font-weight: bold;" t-esc="serial"/>
                                            <td t-if="asset_index == 0" t-att-rowspan="line_count">
                                                <span t-esc="group.get('landowner_name', '')"/><br/>
                                                <t t-if="group.get('father_name')">पिता/पति: <span t-esc="group.get('father_name')"/></t>
                                            </td>
                                            <td style="text-align: center;" t-esc="asset.get('asset_khasra', '')"/>
                                            <td style="text-align: right;" t-esc="o.format_indian_number(asset.get('asset_land_area', 0.0), 3)"/>
                                            <td>
                                                (<span t-esc="asset.get('asset_code', '4')"/>) <span t-esc="asset.get('asset_type', '')"/>
                                            </td>
                                            <td style="text-align: right;" t-esc="o.format_indian_number(asset.get('asset_dimension', 0.0), 2)"/>
                                            <td style="text-align: right;" t-esc="o.format_indian_number(asset.get('market_value', 0.0), 0)"/>
                                            <td style="text-align: right;" t-esc="o.format_indian_number(asset.get('solatium', 0.0), 0)"/>
                                            <td style="text-align: right;" t-esc="o.format_indian_number(asset.get('interest', 0.0), 0)"/>
                                            <td style="text-align: right; font-weight: bold;" t-esc="o.format_indian_number(asset.get('total', 0.0), 0)"/>
                                            <td t-esc="asset.get('remark', '')"/>
                                        </tr>
                                    </t>
                                    <tr class="total-row">
                                        <td colspan="2" style="text-align: center; font-weight: bold;">कुल</td>
                                        <td style="text-align: center; font-weight: bold;" t-esc="group.get('khasra_count', 0)"/>
                                        <td style="text-align: right; font-weight: bold;" t-esc="o.format_indian_number(group.get('asset_land_area', 0.0), 3)"/>
                                        <td style="text-align: center; font-weight: bold;">कुल</td>
                                        <td style="text-align: right; font-weight: bold;" t-esc="o.format_indian_number(group.get('asset_dimension', 0.0), 2)"/>
                                        <td style="text-align: right; font-weight: bold;" t-esc="o.format_indian_number(group.get('market_value', 0.0), 0)"/>
                                        <td style="text-align: right; font-weight: bold;" t-esc="o.format_indian_number(group.get('solatium', 0.0), 0)"/>
                                        <td style="text-align: right; font-weight: bold;" t-esc="o.format_indian_number(group.get('interest', 0.0), 0)"/>
                                        <td style="text-align: right; font-weight: bold;" t-esc="o.format_indian_number(group.get('total', 0.0), 0)"/>
                                        <td></td>
                                    </tr>
                                    <t t-set="serial" t-value="serial + 1"/>
                                </t>
                                <t t-if="not asset_groups">
                                    <tr>
                                        <td colspan="11" style="text-align: center; font-style: italic;">
                                            No asset/structure data available / परिसम्पत्ति डेटा उपलब्ध नहीं है (Blank)
                                        </td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                        <t t-call="bhuarjan.section23_signature_block"/>
                </div>

                <!-- Part 1 (Ga) - TREE COMPENSATION -->
                <div class="page" style="padding: 10px;">
                            <div class="watermark">
                                 <t t-set="base_url" t-value="o.env['ir.config_parameter'].sudo().get_param('web.base.url')"/>
                                 <img t-att-src="base_url + '/bhuarjan/static/img/logo.png'" alt="Logo Watermark"/>
                            </div>

                            <div style="text-align: right; font-size: 12px; font-weight: bold; margin-bottom: 5px;">
                                <span t-esc="award_headers['sections']['tree_sheet_label']"/>
                            </div>

                            <div style="text-align: center; margin-bottom: 10px;">
                                <div style="margin-bottom: 6px;">
                                    <img t-att-src="base_url + '/bhuarjan/static/img/logo.png'" alt="Logo" style="height: 44px; width: auto;"/>
                                </div>
                                <h2 style="margin: 0;"><span t-esc="award_headers['sections']['tree_title']"/></h2>
                                <div style="font-size: 11px; margin-top: 5px;">
                                    मूँ-अर्जन प्रकरण क्रमांक <span t-esc="o.name if o._name == 'bhu.section23.award' else 'Simulation'"/> / <span t-esc="o.award_document_filename if (o._name == 'bhu.section23.award' and o.award_document_filename) else 'अ-82/2022-23'"/>
                                </div>
                            </div>

                            <div style="text-align: center; font-size: 11px; margin-bottom: 10px; font-weight: bold;">
                                ग्राम-<span t-esc="o.village_id.name if o.village_id else ''"/> प.ह.नं.-<span t-esc="o.project_id.name if o.project_id else ''"/> रा.नि.मं.-<span t-esc="''"/> तहसील-<span t-esc="o.village_id.tehsil_id.name if o.village_id and o.village_id.tehsil_id else ''"/> जिला-<span t-esc="o.village_id.district_id.name if o.village_id and o.village_id.district_id else ''"/>
                            </div>

                        <table border="1">
                                <thead>
                                    <tr>
                                        <th rowspan="2" style="width: 30px;">1.<br/>क्र.</th>
                                        <th rowspan="2" style="width: 150px;">2.<br/>भूमिस्वामी का नाम व पिता/पति का नाम</th>
                                        <th colspan="3">भूमि जिस पर वृक्ष स्थित है, का विवरण</th>
                                        <th rowspan="2">6.<br/>गोलाई</th>
                                        <th colspan="2">निर्धारित मूल्य</th>
                                        <th rowspan="2">9.<br/>सोलेशियम 100%</th>
                                        <th rowspan="2">10.<br/>12% ब्याज</th>
                                        <th rowspan="2">11.<br/>योग</th>
                                        <th rowspan="2">12.<br/>रिमार्क</th>
                                    </tr>
                                    <tr>
                                        <th>3.<br/>खसरा नं.</th>
                                        <th>4.<br/>वृक्षों का प्रकार</th>
                                        <th>5.<br/>वृक्ष संख्या</th>
                                        <th>7.<br/>दर</th>
                                        <th>8.<br/>मूल्य</th>
                                    </tr>
                                </thead>
                            <tbody>
                                <t t-set="serial" t-value="1"/>
                                <t t-foreach="tree_groups" t-as="group">
                                    <t t-set="group_lines" t-value="group.get('lines')"/>
                                    <t t-set="line_count" t-value="len(group_lines)"/>
                                    <t t-foreach="group_lines" t-as="tree">
                                        <tr>
                                            <td t-if="tree_index == 0" t-att-rowspan="line_count" style="text-align: center; font-weight: bold;" t-esc="serial"/>
                                            <td t-if="tree_index == 0" t-att-rowspan="line_count">
                                                <span t-esc="group.get('landowner_name', '')"/><br/>
                                                <t t-if="group.get('father_name')">पिता/पति: <span t-esc="group.get('father_name')"/></t>
                                            </td>
                                            <td style="text-align: center;" t-esc="tree.get('khasra', '')"/>
                                            <td>
                                                <span t-esc="tree.get('tree_type', '')"/>
                                            </td>
                                            <td style="text-align: right;" t-esc="o.format_indian_number(tree.get('tree_count', 0), 2)"/>
                                            <td style="text-align: right;" t-esc="o.format_indian_number(tree.get('girth_cm', 0.0), 2)"/>
                                            <td style="text-align: right;" t-esc="o.format_indian_number(tree.get('rate', 0.0), 0)"/>
                                            <td style="text-align: right;" t-esc="o.format_indian_number(tree.get('value', 0.0), 0)"/>
                                            <td style="text-align: right;" t-esc="o.format_indian_number(tree.get('solatium', 0.0), 0)"/>
                                            <td style="text-align: right;" t-esc="o.format_indian_number(tree.get('interest', 0.0), 0)"/>
                                            <td style="text-align: right; font-weight: bold;" t-esc="o.format_indian_number(tree.get('total', 0.0), 0)"/>
                                            <td t-esc="tree.get('remark', '')"/>
                                        </tr>
                                    </t>
                                    <tr class="total-row">
                                        <td colspan="2" style="text-align: center; font-weight: bold;">कुल</td>
                                        <td style="text-align: center; font-weight: bold;" t-esc="group.get('khasra_count', 0)"/>
                                        <td style="text-align: center; font-weight: bold;">-</td>
                                        <td style="text-align: right; font-weight: bold;" t-esc="o.format_indian_number(group.get('tree_count', 0.0), 2)"/>
                                        <td style="text-align: right; font-weight: bold;">-</td>
                                        <td style="text-align: right; font-weight: bold;">-</td>
                                        <td style="text-align: right; font-weight: bold;" t-esc="o.format_indian_number(group.get('value', 0.0), 0)"/>
                                        <td style="text-align: right; font-weight: bold;" t-esc="o.format_indian_number(group.get('solatium', 0.0), 0)"/>
                                        <td style="text-align: right; font-weight: bold;" t-esc="o.format_indian_number(group.get('interest', 0.0), 0)"/>
                                        <td style="text-align: right; font-weight: bold;" t-esc="o.format_indian_number(group.get('total', 0.0), 0)"/>
                                        <td></td>
                                    </tr>
                                    <t t-set="serial" t-value="serial + 1"/>
                                </t>
                                <t t-if="not tree_groups">
                                    <tr>
                                        <td colspan="12" style="text-align: center; font-style: italic;">
                                            No tree data available / वृक्ष डेटा उपलब्ध नहीं है (Blank)
                                        </td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                        <t t-call="bhuarjan.section23_signature_block"/>
                </div>
            </t>
        </t>
    </template>
</odoo>
